// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum LeaveType {
  VACATION
  SICK
  EMERGENCY
  NO_PAY
  OTHERS
}

model Users {
  id Int @id @default(autoincrement())
  first_name String
  middle_name String?
  last_name String
  email String @unique
  password String
  birthday DateTime?
  position_id Int?
  position Positions? @relation(fields: [position_id], references: [id])
  shift_id Int?
  shift Shifts? @relation(fields: [shift_id], references: [id])
  role Role @default(USER)
  timeEntries TimeEntry[]
  ownedCalendarReminders CalendarReminder[] @relation("CalendarReminderOwner")
  sharedCalendarReminders ReminderShare[]
  isActive Boolean @default(true)
  /// Minutes from midnight (GMT+8) when the 9h workday (+1h lunch) starts. Null = 8:00 AM.
  scheduleStartMinutes Int?
  created_at DateTime @default(now())
  updated_at DateTime? @updatedAt
}

model Positions {
  id Int @id @default(autoincrement())
  title String @unique
  users Users[]
  created_at DateTime @default(now())
  updated_at DateTime? @updatedAt
}

model Shifts {
  id Int @id @default(autoincrement())
  title String @unique
  start_time DateTime @db.Time(0)
  end_time DateTime @db.Time(0)
  users Users[]
  created_at DateTime @default(now())
  updated_at DateTime? @updatedAt
}

model TimeEntry {
  id           Int       @id @default(autoincrement())
  userId       Int
  user         Users     @relation(fields: [userId], references: [id])

  clockIn      DateTime
  clockOut     DateTime?      // nullable while still on shift
  breakMinutes Int      @default(0)
  totalHours   Decimal?
  status       String
  notes        String?
  taskDescription String?
  kind         String
  isLate       Boolean?       // true if first Time In of day was after 8:00 AM GMT+8

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CalendarReminder {
  id Int @id @default(autoincrement())
  ownerId Int
  owner Users @relation("CalendarReminderOwner", fields: [ownerId], references: [id])
  date DateTime
  title String
  note String?
  time String?
  shares ReminderShare[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, date])
}

model ReminderShare {
  id Int @id @default(autoincrement())
  reminderId Int
  userId Int
  reminder CalendarReminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  user Users @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([reminderId, userId])
  @@index([userId])
}